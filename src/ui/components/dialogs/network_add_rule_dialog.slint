import {
    Theme,
    AppI18n,
    LayoutConstants,
} from "../../theme.slint";
import { CustomLineEdit, CustomComboBox, CustomCheckBox } from "../form_widgets.slint";

export component NetworkAddRuleDialog inherits Rectangle {
    in property <[string]> distro_names: [];
    in property <[string]> local_ips: [];
    
    in-out property <int> distro_idx: 0;
    in-out property <int> ip_idx: 0;
    in-out property <string> listen_port: "";
    in-out property <string> target_port: "";
    in-out property <bool> enable_fw: true;

    in property <string> error_msg: "";

    callback close;
    callback add(string, string, string, string, bool);
    
    // Background mask
    background: #00000080;
    
    // Trap clicks
    TouchArea { }

    // Dialog Box
    Rectangle {
        width: 500px;
        height: 380px;
        background: Theme.card_bg;
        border-radius: 8px;
        border-width: 1px;
        border-color: Theme.border_color;
        TouchArea { /* prevent click through */ }

        VerticalLayout {
            padding: 24px;
            spacing: 0px;
            
            // Header
            HorizontalLayout {
                padding-bottom: 16px;
                
                if (AppI18n.is-rtl): TouchArea {
                    width: 24px;
                    height: 24px;
                    clicked => {
                        root.close();
                    }
                    Rectangle {
                        background: parent.has-hover ? Theme.hover_bg : transparent;
                        border-radius: 4px;
                        Text {
                            text: "\u{E8BB}";
                            font-family: Theme.icon_font;
                            font-size: 14px;
                            color: Theme.text_primary;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                Text {
                    text: AppI18n.t("dialog.add_network_rule_title", [AppI18n.version]);
                    font-size: 18px * LayoutConstants.font-scale;
                    font-family: Theme.default_font;
                    font-weight: 500;
                    color: Theme.text_primary;
                    horizontal-alignment: AppI18n.is-rtl ? right : left;
                    horizontal-stretch: 1;
                }

                if (!AppI18n.is-rtl): TouchArea {
                    width: 24px;
                    height: 24px;
                    clicked => {
                        root.close();
                    }
                    Rectangle {
                        background: parent.has-hover ? Theme.hover_bg : transparent;
                        border-radius: 4px;
                        Text {
                            text: "\u{E8BB}";
                            font-family: Theme.icon_font;
                            font-size: 14px;
                            color: Theme.text_primary;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            Rectangle {
                height: 1px;
                background: Theme.border_color;
            }

            Rectangle {
                height: 24px;
            } // Spacer

            // Content
            VerticalLayout {
                spacing: 16px;
                horizontal-stretch: 1;

                // Listen IP
                HorizontalLayout {
                    spacing: 12px;
                    alignment: AppI18n.is-rtl ? end : start;
                    
                    if (AppI18n.is-rtl): CustomComboBox {
                        width: 300px;
                        model: root.local_ips;
                        current-index <=> root.ip_idx;
                    }

                    Text {
                        text: AppI18n.t("network.add_rule_listen_ip", [AppI18n.version]) + ":";
                        width: 110px;
                        vertical-alignment: center;
                        horizontal-alignment: AppI18n.is-rtl ? right : left;
                        color: Theme.text_secondary;
                        font-family: Theme.default_font;
                    }
                    
                    if (!AppI18n.is-rtl): CustomComboBox {
                        width: 300px;
                        model: root.local_ips;
                        current-index <=> root.ip_idx;
                    }
                }

                // Listen Port
                HorizontalLayout {
                    spacing: 12px;
                    alignment: AppI18n.is-rtl ? end : start;

                    if (AppI18n.is-rtl): CustomLineEdit {
                        width: 300px;
                        text <=> root.listen_port;
                        placeholder-text: AppI18n.t("network.add_rule_port_placeholder", [AppI18n.version]);
                        edited(t) => {
                            // Sync full content to target_port
                            root.target_port = t;
                        }
                    }

                    Text {
                        text: AppI18n.t("network.add_rule_listen_port", [AppI18n.version]) + ":";
                        width: 110px;
                        vertical-alignment: center;
                        horizontal-alignment: AppI18n.is-rtl ? right : left;
                        color: Theme.text_secondary;
                        font-family: Theme.default_font;
                    }

                    if (!AppI18n.is-rtl): CustomLineEdit {
                        width: 300px;
                        text <=> root.listen_port;
                        placeholder-text: AppI18n.t("network.add_rule_port_placeholder", [AppI18n.version]);
                        edited(t) => {
                            // Sync full content to target_port
                            root.target_port = t;
                        }
                    }
                }

                // Target Distro
                HorizontalLayout {
                    spacing: 12px;
                    alignment: AppI18n.is-rtl ? end : start;

                    if (AppI18n.is-rtl): CustomComboBox {
                        width: 300px;
                        model: root.distro_names;
                        current-index <=> root.distro_idx;
                    }

                    Text {
                        text: AppI18n.t("network.target_distro", [AppI18n.version]) + ":";
                        width: 110px;
                        vertical-alignment: center;
                        horizontal-alignment: AppI18n.is-rtl ? right : left;
                        color: Theme.text_secondary;
                        font-family: Theme.default_font;
                    }

                    if (!AppI18n.is-rtl): CustomComboBox {
                        width: 300px;
                        model: root.distro_names;
                        current-index <=> root.distro_idx;
                    }
                }

                // Target Port
                HorizontalLayout {
                    spacing: 12px;
                    alignment: AppI18n.is-rtl ? end : start;

                    if (AppI18n.is-rtl): CustomLineEdit {
                        width: 300px;
                        text <=> root.target_port;
                        placeholder-text: AppI18n.t("network.add_rule_target_port_placeholder", [AppI18n.version]);
                    }

                    Text {
                        text: AppI18n.t("network.add_rule_target_port", [AppI18n.version]) + ":";
                        width: 110px;
                        vertical-alignment: center;
                        horizontal-alignment: AppI18n.is-rtl ? right : left;
                        color: Theme.text_secondary;
                        font-family: Theme.default_font;
                    }

                    if (!AppI18n.is-rtl): CustomLineEdit {
                        width: 300px;
                        text <=> root.target_port;
                        placeholder-text: AppI18n.t("network.add_rule_target_port_placeholder", [AppI18n.version]);
                    }
                }

                // Firewall Row
                HorizontalLayout {
                    spacing: 12px;
                    alignment: AppI18n.is-rtl ? end : start;
                    
                    if (!AppI18n.is-rtl): Rectangle { width: 110px; } // LTR Spacer on left
                    
                    CustomCheckBox {
                        text: AppI18n.t("network.add_rule_enable_fw", [AppI18n.version]);
                        checked <=> root.enable_fw;
                    }

                    if (AppI18n.is-rtl): Rectangle { width: 110px; } // RTL Spacer on right
                }
            }

            Rectangle {
                vertical-stretch: 1;
            } // Spacer

            // Error Message
            if root.error_msg != "": HorizontalLayout {
                padding-bottom: 8px;
                alignment: center;
                Text {
                    text: root.error_msg;
                    color: #ff3333;
                    font-size: 13px * LayoutConstants.font-scale;
                    font-family: Theme.default_font;
                }
            }

            // Footer
            HorizontalLayout {
                alignment: AppI18n.is-rtl ? start : end;
                spacing: 12px;
                
                // RTL: Submit first (outer), then Cancel
                if (AppI18n.is-rtl): Rectangle {
                    width: 90px;
                    height: 32px;
                    background: Theme.accent;
                    border-radius: 6px;
                    TouchArea {
                        clicked => {
                            if (root.listen_port != "" && root.target_port != "" && root.distro_names.length > 0 && root.local_ips.length > 0) {
                                root.add(
                                    root.distro_names[root.distro_idx],
                                    root.local_ips[root.ip_idx],
                                    root.listen_port,
                                    root.target_port,
                                    root.enable_fw
                                );
                            }
                        }
                    }

                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        spacing: 6px;
                        alignment: center;
                        
                        Text {
                            text: AppI18n.t("dialog.add", [AppI18n.version]);
                            color: white;
                            font-size: 13px * LayoutConstants.font-scale;
                            font-family: Theme.default_font;
                            font-weight: 500;
                            vertical-alignment: center;
                        }

                        Rectangle {
                            width: 14px;
                            height: 14px;
                            y: (parent.height - self.height) / 2;
                            Image {
                                source: @image-url("../../../../assets/feat/microsoft-shield.png");
                                width: 12px;
                                height: 12px;
                                image-fit: contain;
                            }
                        }
                    }
                }

                if (AppI18n.is-rtl): Rectangle {
                    width: 90px;
                    height: 32px;
                    background: transparent;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: Theme.border_color;
                    TouchArea {
                        clicked => {
                            root.close();
                        }
                        Rectangle {
                            background: parent.has-hover ? Theme.hover_bg : transparent;
                            border-radius: 6px;
                        }
                    }

                    Text {
                        text: AppI18n.t("dialog.cancel", [AppI18n.version]);
                        color: Theme.text_primary;
                        font-size: 13px * LayoutConstants.font-scale;
                        font-family: Theme.default_font;
                        font-weight: 500;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                // LTR: Cancel first, then Submit
                if (!AppI18n.is-rtl): Rectangle {
                    width: 90px;
                    height: 32px;
                    background: transparent;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: Theme.border_color;
                    TouchArea {
                        clicked => {
                            root.close();
                        }
                        Rectangle {
                            background: parent.has-hover ? Theme.hover_bg : transparent;
                            border-radius: 6px;
                        }
                    }

                    Text {
                        text: AppI18n.t("dialog.cancel", [AppI18n.version]);
                        color: Theme.text_primary;
                        font-size: 13px * LayoutConstants.font-scale;
                        font-family: Theme.default_font;
                        font-weight: 500;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
                
                if (!AppI18n.is-rtl): Rectangle {
                    width: 90px;
                    height: 32px;
                    background: Theme.accent;
                    border-radius: 6px;
                    TouchArea {
                        clicked => {
                            if (root.listen_port != "" && root.target_port != "" && root.distro_names.length > 0 && root.local_ips.length > 0) {
                                root.add(
                                    root.distro_names[root.distro_idx],
                                    root.local_ips[root.ip_idx],
                                    root.listen_port,
                                    root.target_port,
                                    root.enable_fw
                                );
                            }
                        }
                    }

                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        spacing: 6px;
                        alignment: center;
                        
                        Text {
                            text: AppI18n.t("dialog.add", [AppI18n.version]);
                            color: white;
                            font-size: 13px * LayoutConstants.font-scale;
                            font-family: Theme.default_font;
                            font-weight: 500;
                            vertical-alignment: center;
                        }

                        Rectangle {
                            width: 14px;
                            height: 14px;
                            y: (parent.height - self.height) / 2;
                            Image {
                                source: @image-url("../../../../assets/feat/microsoft-shield.png");
                                width: 12px;
                                height: 12px;
                                image-fit: contain;
                            }
                        }
                    }
                }
            }
        }
    }
}
