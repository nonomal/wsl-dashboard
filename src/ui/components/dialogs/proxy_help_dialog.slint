import { Theme, AppI18n, LayoutConstants } from "../../theme.slint";
import { CustomButton } from "../form_widgets.slint";

export component ProxyHelpDialog inherits Rectangle {
    callback close;
    width: 500px;
    height: proxy_layout.preferred-height;
    background: Theme.card_bg;
    border-radius: 8px;
    border-width: 1px;
    border-color: Theme.border_color;

    proxy_layout := VerticalLayout {
        padding: 24px;
        spacing: 8px; // matches information_dialog
        
        // Header: title + close button
        Rectangle {
            height: 24px;
            Text {
                x: AppI18n.is-rtl ? 32px : 0;
                width: parent.width - 32px;
                text: AppI18n.t("dialog.http_proxy_helper", []);
                font-size: 18px * LayoutConstants.font-scale;
                font-family: Theme.default_font;
                font-weight: 500;
                color: Theme.text_primary;
                horizontal-alignment: AppI18n.is-rtl ? right : left;
                vertical-alignment: center;
            }
            TouchArea {
                x: AppI18n.is-rtl ? 0 : parent.width - self.width;
                width: 24px;
                height: 24px;
                clicked => { root.close(); }
                Rectangle {
                    background: parent.has-hover ? Theme.hover_bg : transparent;
                    border-radius: 4px;
                    Text {
                        text: "\u{E8BB}";
                        font-family: Theme.icon_font;
                        font-size: 14px;
                        color: Theme.text_primary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // Divider
        Rectangle {
            height: 1px;
            background: Theme.border_color;
        }

        VerticalLayout {
            spacing: 16px;
            
        HorizontalLayout {
            spacing: 16px;
            alignment: AppI18n.is-rtl ? end : start;
            
            // RTL: Text then Icon
            if (AppI18n.is-rtl): VerticalLayout {
                spacing: 12px;
                
                Text {
                    text: AppI18n.t("dialog.http_proxy_helper_desc1", []);
                    font-size: 14px * LayoutConstants.font-scale;
                    font-family: Theme.default_font;
                    color: Theme.text_primary;
                    wrap: word-wrap;
                    horizontal-alignment: right;
                }

                Text {
                    text: AppI18n.t("dialog.http_proxy_helper_desc2", []);
                    font-size: 14px * LayoutConstants.font-scale;
                    font-family: Theme.default_font;
                    color: Theme.text_secondary;
                    wrap: word-wrap;
                    horizontal-alignment: right;
                }
            }

            // Icon in a blue circle
            Rectangle {
                width: 32px;
                height: 32px;
                border-radius: 16px;
                background: Theme.accent;
                
                Text {
                    text: "\u{E9ce}"; // Question mark
                    font-family: Theme.icon_font;
                    font-size: 18px;
                    color: white;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
            }

            // LTR: Icon then Text
            if (!AppI18n.is-rtl): VerticalLayout {
                spacing: 12px;
                
                Text {
                    text: AppI18n.t("dialog.http_proxy_helper_desc1", []);
                    font-size: 14px * LayoutConstants.font-scale;
                    font-family: Theme.default_font;
                    color: Theme.text_primary;
                    wrap: word-wrap;
                    horizontal-alignment: left;
                }

                Text {
                    text: AppI18n.t("dialog.http_proxy_helper_desc2", []);
                    font-size: 14px * LayoutConstants.font-scale;
                    font-family: Theme.default_font;
                    color: Theme.text_secondary;
                    wrap: word-wrap;
                    horizontal-alignment: left;
                }
            }
        }
        }

        // Footer
        HorizontalLayout {
            alignment: AppI18n.is-rtl ? start : end;
            CustomButton {
                text: AppI18n.t("dialog.confirm", [AppI18n.version]);
                height: 32px;
                width: 100px;
                primary: true;
                clicked => { root.close(); }
            }
        }
    }
}
