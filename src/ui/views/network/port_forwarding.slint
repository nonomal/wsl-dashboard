import {
    Theme,
    AppI18n,
    PortProxyRuleUI,
    LayoutConstants,
} from "../../theme.slint";
import { CustomButton } from "../../components/form_widgets.slint";
import { CustomScrollbar } from "../../components/scrollbar.slint";
import { NetworkRuleCard } from "../../components/network_rule_card.slint";

export component PortForwardingView inherits Rectangle {
    in property <bool> is_helper_installed: false;
    in property <string> networking_mode: "NAT";
    in property <[PortProxyRuleUI]> rules: [];

    callback initialize_task_clicked();
    callback open_add_rule_dialog();
    callback delete_rule(string);
    callback process_rule(string);
    callback cancel_rule(string);
    callback apply_all_rules();
    callback cancel_all_rules();

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        // Content
        Rectangle {
            vertical-stretch: 1;
            clip: true;

            flick := Flickable {
                viewport-height: container.preferred-height;
                width: parent.width;
                height: 100%;

                container := VerticalLayout {
                    spacing: 8px;
                    padding-top: 4px;
                    padding-bottom: 6px;
                    padding-left: 4px;
                    padding-right: 16px;

                    if (root.networking_mode == "NAT"): VerticalLayout {
                        spacing: 8px;
                        
                        // Rules list
                        VerticalLayout {
                            spacing: 8px;
                            for rule[i] in root.rules: NetworkRuleCard {
                                rule: rule;
                                delete_clicked => {
                                    root.delete_rule(rule.id);
                                }
                                process_clicked => {
                                    root.process_rule(rule.id);
                                }
                                cancel_clicked => {
                                    root.cancel_rule(rule.id);
                                }
                            }
                        }

                        if (root.rules.length == 0): VerticalLayout {
                            alignment: center;
                            spacing: 12px;
                            padding: 40px;
                            Text {
                                text: AppI18n.t("network.no_rules", [AppI18n.version]);
                                horizontal-alignment: center;
                                color: Theme.text_secondary;
                                font-family: Theme.default_font;
                                font-size: 14px * LayoutConstants.font-scale;
                            }
                        }
                    }

                    if (root.networking_mode != "NAT"): VerticalLayout {
                        alignment: center;
                        padding: 60px;
                        spacing: 20px;
                        Text {
                            text: "\u{E968}";
                            font-family: Theme.icon_font;
                            color: Theme.accent;
                            font-size: 32px * LayoutConstants.font-scale;
                            horizontal-alignment: center;
                            opacity: 0.3;
                        }

                        Text {
                            text: AppI18n.t("network.nat_mode_required", [root.networking_mode]);
                            horizontal-alignment: center;
                            color: Theme.text_secondary;
                            font-family: Theme.default_font;
                            font-size: 15px * LayoutConstants.font-scale;
                            wrap: word-wrap;
                            max-width: 400px;
                        }
                    }
                }
            }

            CustomScrollbar {
                opacity: (flick.viewport-height > flick.height) ? 1 : 0;
                visible: flick.viewport-height > flick.height;
                x: AppI18n.is-rtl ? 2px : parent.width - 8px;
                y: 0;
                width: 8px;
                height: 100%;
                maximum: flick.viewport-height - flick.height;
                page_size: flick.height;
                value: -flick.viewport-y;
                scroll_to(v) => {
                    flick.viewport-y = -v;
                }
            }
        }

        // Bottom Bar
        if (root.networking_mode == "NAT"): HorizontalLayout {
            padding-top: 4px;
            padding-bottom: 4px;
            padding-right: AppI18n.is-rtl ? 4px : 12px;
            padding-left: AppI18n.is-rtl ? 12px : 4px;
            spacing: 8px;

            if (!AppI18n.is-rtl && !is_helper_installed): CustomButton {
                text: AppI18n.t("network.initialize_btn", [AppI18n.version]);
                show_shield: true;
                height: 32px;
                clicked => {
                    root.initialize_task_clicked();
                }
            }

            if (AppI18n.is-rtl): CustomButton {
                text: AppI18n.t("network.add_rule_btn", [AppI18n.version]);
                primary: true;
                height: 32px;
                clicked => {
                    root.open_add_rule_dialog();
                }
            }

            Rectangle {
                horizontal-stretch: 1;
            }

            if (!AppI18n.is-rtl): CustomButton {
                text: AppI18n.t("network.cancel_all_rules_btn", [AppI18n.version]);
                show_shield: true;
                height: 32px;
                clicked => {
                    root.cancel_all_rules();
                }
            }

            if (!AppI18n.is-rtl): CustomButton {
                text: AppI18n.t("network.apply_all_rules_btn", [AppI18n.version]);
                show_shield: true;
                height: 32px;
                clicked => {
                    root.apply_all_rules();
                }
            }

            if (!AppI18n.is-rtl): CustomButton {
                text: AppI18n.t("network.add_rule_btn", [AppI18n.version]);
                primary: true;
                show_shield: true;
                height: 32px;
                clicked => {
                    root.open_add_rule_dialog();
                }
            }

            if (AppI18n.is-rtl): CustomButton {
                text: AppI18n.t("network.apply_all_rules_btn", [AppI18n.version]);
                show_shield: true;
                height: 32px;
                clicked => {
                    root.apply_all_rules();
                }
            }

            if (AppI18n.is-rtl): CustomButton {
                text: AppI18n.t("network.cancel_all_rules_btn", [AppI18n.version]);
                show_shield: true;
                height: 32px;
                clicked => {
                    root.cancel_all_rules();
                }
            }

            if (AppI18n.is-rtl && !is_helper_installed): CustomButton {
                text: AppI18n.t("network.initialize_btn", [AppI18n.version]);
                show_shield: true;
                height: 32px;
                clicked => {
                    root.initialize_task_clicked();
                }
            }
        }
    }
}
